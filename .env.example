# =====================================================================
# AlertNetwork — environment variables
# Copy this file to `.env.local` for local dev and set the same keys in
# Vercel → Settings → Environment Variables for deployed environments.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase
# Get these from supabase.com → your project → Settings → API.
# ---------------------------------------------------------------------

# Public Postgres-REST + auth endpoint. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous public key. Safe to expose; RLS gates everything.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. NEVER expose to the browser. Only used by the cron
# route (`/api/cron/daily`) and admin scripts.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Apify — TikTok scraper actor (apidojo~tiktok-scraper-api)
# Get from apify.com → Settings → Integrations → Personal API tokens.
# ---------------------------------------------------------------------

APIFY_API_KEY=

# ---------------------------------------------------------------------
# Cron auth
# Shared secret for `/api/cron/daily` and `/api/cron/reports`. Generate
# with:
#   openssl rand -hex 32
#
# Set BOTH of these in Vercel → Settings → Environment Variables
# (Production / Preview / Development) to the same value:
#
#   CRON_SHARED_SECRET  — used by the GitHub Actions backup workflow,
#                        which sends `Authorization: Bearer ${CRON_SHARED_SECRET}`.
#   CRON_SECRET         — used by Vercel Cron itself. Vercel will ONLY
#                        attach `Authorization: Bearer ${CRON_SECRET}`
#                        to its outgoing cron requests if this env var
#                        is set. If you only set CRON_SHARED_SECRET,
#                        Vercel Cron sends no auth header and the route
#                        returns 401, silently making the daily scrape
#                        a no-op.
#
# Also mirror CRON_SHARED_SECRET as a GitHub Actions repository secret.
# ---------------------------------------------------------------------

CRON_SHARED_SECRET=
CRON_SECRET=
